# .env.local — Copy this and fill in your API keys

# ElevenLabs (required for Speech-to-Text and Text-to-Speech)
# Sign up at https://elevenlabs.io/ → Profile → API Keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google Cloud Translation API (required for translation)
# Enable the API in Google Cloud Console and create an API key
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Upstash Redis (required for Display mode session bridge)
# Sign up at https://upstash.com/ → Create Redis Database → REST API
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
