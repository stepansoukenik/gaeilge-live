# .env.local — Copy this and fill in your API key
# Choose ONE of the following:

# Option A: Lingvanex (recommended for Irish, has free tier)
# Sign up at https://lingvanex.com/ and get your API key
LINGVANEX_API_KEY=your_lingvanex_api_key_here

# Option B: Google Cloud Translation API
# Enable the API in Google Cloud Console and create an API key
# GOOGLE_TRANSLATE_API_KEY=your_google_api_key_here

